# ── API Authentication ────────────────────────────────────
# Used by the Vite dev server and frontend nginx proxy.
# Must match the backend API_KEY value.
VITE_API_KEY=same-as-backend-api-key

# Optional override for the backend service URL in the frontend nginx proxy.
# Local Docker default: http://backend:8000
BACKEND_URL=http://backend:8000
